{
  "name": "kanbeasy",
  "displayName": "Kanbeasy",
  "description": "A minimal, easy to use kanban board within VS Code. Orgranize your tasks effortlessly.",
  "publisher": "darrenjaworski",
  "version": "1.3.1",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.103.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/darrenjaworski/vscode-kanbeasy.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kanbeasy",
          "title": "Kanbeasy",
          "icon": "resources/kanbeasy-icon.svg"
        }
      ]
    },
    "views": {
      "kanbeasy": [
        {
          "id": "kanbeasyView",
          "name": "Kanban Board"
        }
      ]
    },
    "commands": [
      {
        "command": "kanbeasy.openBoard",
        "title": "Open Kanbeasy Board"
      },
      {
        "command": "kanbeasy.toggleBoard",
        "title": "Toggle Kanbeasy Board"
      }
    ],
    "viewsWelcome": [
      {
        "view": "kanbeasyView",
        "contents": "Click the button below to open your Kanban Board.\n[Open Kanban Board](command:kanbeasy.toggleBoard)"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "kanbeasy.mcp",
        "label": "Kanbeasy Board"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test:unit": "tsc -p . --outDir out && mocha \"out/test/unit/**/*.test.js\"",
    "test": "vscode-test",
    "vsce-package": "npx vsce package",
    "kitchen-sink": "npm run compile && npm run test && npm run vsce-package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.103.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.8",
    "eslint": "^10.5.0",
    "mocha": "^11.7.6",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2"
  },
  "allowScripts": {
    "esbuild@0.25.8": true,
    "fsevents@2.3.3": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
